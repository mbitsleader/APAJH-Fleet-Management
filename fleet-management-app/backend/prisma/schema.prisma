generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Pole {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  isActive  Boolean    @default(true)
  services  Service[]
  userPoles UserPole[]
}

model Service {
  id           String        @id @default(uuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  poleId       String?
  pole         Pole?         @relation(fields: [poleId], references: [id])
  userServices UserService[]
  vehicles     Vehicle[]
}

model UserPole {
  userId String
  poleId String
  pole   Pole   @relation(fields: [poleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, poleId])
}

model UserService {
  userId    String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, serviceId])
}

model User {
  id                  String                 @id @default(uuid())
  entraId             String                 @unique
  email               String                 @unique
  name                String
  role                Role                   @default(PROFESSIONNEL)
  department          String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  passwordHash        String?
  deletedAt           DateTime?
  cleaningAssignments CleaningAssignment[]
  cleaningLogs        CleaningLog[]
  fuelLogs            FuelLog[]
  incidents           Incident[]
  refreshTokens       RefreshToken[]
  reservations        Reservation[]
  passengerOn         ReservationPassenger[]
  tripLogs            TripLog[]
  userPoles           UserPole[]
  userServices        UserService[]
  assignedVehicles    Vehicle[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Vehicle {
  id                      String             @id @default(uuid())
  plateNumber             String             @unique
  brand                   String
  model                   String
  status                  VehicleStatus      @default(AVAILABLE)
  category                String?
  currentMileage          Int
  fuelType                String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  imageUrl                String?
  assignedUserId          String?
  lowFuel                 Boolean            @default(false)
  serviceId               String?
  type                    VehicleType        @default(PERMANENT)
  deletedAt               DateTime?
  nextTechnicalInspection DateTime?
  cleaningSchedules       CleaningSchedule[]
  fuelLogs                FuelLog[]
  incidents               Incident[]
  maintenanceAlert        MaintenanceAlert[]
  reservations            Reservation[]
  tripLogs                TripLog[]
  assignedUser            User?              @relation(fields: [assignedUserId], references: [id])
  service                 Service?           @relation(fields: [serviceId], references: [id])
}

model CleaningSchedule {
  id          String               @id @default(uuid())
  vehicleId   String
  weekStart   DateTime
  isDone      Boolean              @default(false)
  notes       String?
  createdAt   DateTime             @default(now())
  plannedDays String?
  assignments CleaningAssignment[]
  logs        CleaningLog[]
  vehicle     Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, weekStart])
  @@index([vehicleId])
  @@index([weekStart])
}

model CleaningLog {
  id         String           @id @default(uuid())
  scheduleId String
  userId     String
  date       DateTime
  notes      String?
  createdAt  DateTime         @default(now())
  schedule   CleaningSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id])

  @@unique([scheduleId, date, userId])
}

model CleaningAssignment {
  id          String           @id @default(uuid())
  scheduleId  String
  userId      String
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  schedule    CleaningSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
}

model Reservation {
  id             String                 @id @default(uuid())
  userId         String
  vehicleId      String
  startTime      DateTime
  endTime        DateTime
  approvalStatus ApprovalStatus         @default(APPROVED)
  destination    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id])
  vehicle        Vehicle                @relation(fields: [vehicleId], references: [id])
  passengers     ReservationPassenger[]
  tripLogs       TripLog[]

  @@index([vehicleId, startTime, endTime])
  @@index([vehicleId])
  @@index([userId])
  @@index([startTime])
  @@index([endTime])
}

model ReservationPassenger {
  reservationId String
  userId        String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reservationId, userId])
  @@index([userId])
}

model TripLog {
  id            String       @id @default(uuid())
  reservationId String?
  userId        String
  vehicleId     String
  startMileage  Int
  endMileage    Int?
  startTime     DateTime     @default(now())
  endTime       DateTime?
  destination   String?
  notes         String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([userId])
}

model FuelLog {
  id            String   @id @default(uuid())
  vehicleId     String
  userId        String
  date          DateTime @default(now())
  liters        Float?
  cost          Float?
  mileageAtFill Int?
  user          User     @relation(fields: [userId], references: [id])
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([userId])
}

model Incident {
  id          String           @id @default(uuid())
  vehicleId   String
  userId      String
  description String
  severity    IncidentSeverity @default(MINOR)
  status      IncidentStatus   @default(OPEN)
  createdAt   DateTime         @default(now())
  resolvedAt  DateTime?
  photoUrl    String?
  user        User             @relation(fields: [userId], references: [id])
  vehicle     Vehicle          @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([userId])
}

model MaintenanceAlert {
  id         String   @id @default(uuid())
  vehicleId  String
  type       String
  expiryDate DateTime
  isResolved Boolean  @default(false)
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

enum Role {
  ADMIN
  DIRECTEUR
  MANAGER
  PROFESSIONNEL
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  BLOCKED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IncidentSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

enum IncidentStatus {
  OPEN
  RESOLVED
}

enum VehicleType {
  PERMANENT
  REPLACEMENT
}

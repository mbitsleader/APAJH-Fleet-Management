DATABASE_URL="postgresql://fleet_user:fleet_dev_password@localhost:5432/fleet_db?schema=public"
JWT_SECRET=GENERATE_A_STRONG_RANDOM_KEY_64_BYTES
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_STRONG_RANDOM_KEY_64_BYTES
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"
# ⚠️ CHANGER EN "production" POUR LE DÉPLOIEMENT
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# ── LDAP / Active Directory (optionnel) ──────────────────────────────────────
# Laisser vide (ou supprimer ces lignes) pour désactiver LDAP et utiliser
# uniquement l'authentification locale (email + mot de passe de l'application).
# Si LDAP_URL est défini, l'AD sera testé en priorité à chaque connexion ;
# en cas d'échec, l'authentification locale prend le relais (mode hybride).
#
# LDAP_URL=ldap://192.168.1.1:389
# LDAP_BASE_DN=DC=apajh,DC=local
# LDAP_BIND_DN=CN=svc-appli,OU=ServiceAccounts,DC=apajh,DC=local
# LDAP_BIND_PASSWORD=mot-de-passe-compte-service
# LDAP_USER_SEARCH_BASE=OU=Utilisateurs,DC=apajh,DC=local
